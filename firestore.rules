rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'lastLoginAt']) &&
             data.keys().size() <= 10 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             data.lastLoginAt is timestamp &&
             (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             (!data.keys().hasAny(['isPremium']) || (data.isPremium is bool)) &&
             (!data.keys().hasAny(['premiumPaymentId']) || (data.premiumPaymentId is string && data.premiumPaymentId.size() <= 128)) &&
             (!data.keys().hasAny(['premiumOrderId']) || (data.premiumOrderId is string && data.premiumOrderId.size() <= 128)) &&
             (!data.keys().hasAny(['premiumActivatedAt']) || (data.premiumActivatedAt is string && data.premiumActivatedAt.size() <= 128));
    }

    function isValidPrompt(data) {
      return data.keys().hasAll(['userId', 'prompt', 'promptType', 'createdAt', 'customInstructions']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.prompt is string && data.prompt.size() <= 10000 &&
             data.promptType is string && data.promptType.size() <= 64 &&
             data.customInstructions is string && data.customInstructions.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    // Rules for /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == existing().createdAt && (incoming().lastLoginAt == request.time || incoming().lastLoginAt == existing().lastLoginAt);
    }

    // Rules for /users/{userId}/prompts/{promptId}
    match /users/{userId}/prompts/{promptId} {
      allow list: if isOwner(userId) && isValidId(userId);
      allow get: if isOwner(userId) && isValidId(userId) && isValidId(promptId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidId(promptId) && isValidPrompt(incoming()) && incoming().createdAt == request.time;
      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(promptId);
    }
  }
}
